{
  "openapi": "3.1.0",
  "info": {
    "title": "auth.ericminassian.com",
    "description": "Personal OIDC provider — SPA API and token endpoint.",
    "license": {
      "name": "MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/account": {
      "delete": {
        "tags": [
          "account"
        ],
        "summary": "DELETE /api/account — permanently delete the account and everything bound\nto it: passkeys, sessions (each cascading to refresh families +\nback-channel logout), then the user record itself.",
        "description": "Requires a recent WebAuthn step-up. Deletion is irreversible by design (no\nhelp-desk, no undelete), so the single most catastrophic action gets the\nsame fresh-assertion gate as adding a passkey or rotating recovery codes —\na stolen bearer session (e.g. an XSS riding the host-only cookie past the\nCSRF Origin check) must not be able to destroy the account silently.",
        "operationId": "delete_account",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "401": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Step-up re-authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "account"
        ],
        "summary": "PATCH /api/account — update the display nickname. `updated_at` is bumped,\nwhich the `profile` scope surfaces to RPs (id_token/userinfo) so they can\nrefresh cached copies; the SPA also signals the platform passkey manager\n(`signalCurrentUserDetails`) so passkey entries show the new name.",
        "operationId": "update_account",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAccountRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "400": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/credential-review/complete": {
      "post": {
        "tags": [
          "account"
        ],
        "summary": "POST /api/account/credential-review/complete — the owner has reviewed\n(kept or deleted) every passkey that survived a recovery; clear the flag\nthat blocks `/oauth/authorize`. Deletions themselves go through the\nnormal passkey-deletion endpoint (with its step-up gate and session\ncascade) before this is called.",
        "operationId": "complete_credential_review",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/passkeys": {
      "get": {
        "tags": [
          "account"
        ],
        "summary": "GET /api/account/passkeys",
        "operationId": "list_passkeys",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PasskeyList"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/passkeys/{credential_id}": {
      "delete": {
        "tags": [
          "account"
        ],
        "summary": "DELETE /api/account/passkeys/{credential_id} — refuses to delete the last\npasskey (account lockout guard; recovery would be the only way back in).",
        "description": "Requires a recent WebAuthn step-up: a stolen bearer session must not be able\nto strip the account down to a single attacker-controlled factor. Deleting a\npasskey also revokes every session bound to it (CAEP credential-change\nsemantics, applied locally) — each cascading to its refresh families and\nback-channel logout — so removing a lost or compromised passkey actually\nsevers the access it minted, including the caller's own session when it was\nestablished by that passkey.",
        "operationId": "delete_passkey",
        "parameters": [
          {
            "name": "credential_id",
            "in": "path",
            "description": "base64url credential id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeletePasskeyResponse"
                }
              }
            }
          },
          "404": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Cannot delete the only passkey, or step-up re-authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "account"
        ],
        "summary": "PATCH /api/account/passkeys/{credential_id}",
        "operationId": "rename_passkey",
        "parameters": [
          {
            "name": "credential_id",
            "in": "path",
            "description": "base64url credential id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RenameRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "404": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/recovery-codes": {
      "post": {
        "tags": [
          "account"
        ],
        "summary": "POST /api/account/recovery-codes — (re)generate the account's recovery\ncodes, returning them exactly once. Requires a recent WebAuthn step-up\n(`/api/webauthn/reauth/*`); a fresh login also counts.",
        "operationId": "generate_recovery_codes",
        "responses": {
          "200": {
            "description": "Newly generated codes (shown once)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecoveryCodes"
                }
              }
            }
          },
          "409": {
            "description": "Step-up re-authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/recovery-readiness": {
      "get": {
        "tags": [
          "account"
        ],
        "summary": "GET /api/account/recovery-readiness — how protected the account is against\ndevice loss (passkey count + remaining recovery codes), for nudging the user\nto add a backup passkey or save recovery codes.",
        "operationId": "recovery_readiness",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecoveryReadiness"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/sessions": {
      "get": {
        "tags": [
          "account"
        ],
        "summary": "GET /api/account/sessions",
        "operationId": "list_sessions",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionList"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/sessions/revoke-others": {
      "post": {
        "tags": [
          "account"
        ],
        "summary": "POST /api/account/sessions/revoke-others — sign out everywhere else: one\ncall revokes every session except the caller's (each cascading to refresh\nfamilies + back-channel logout). One rate token and one audit event for\nthe whole sweep — the previous SPA-side per-session loop burned a rate\ntoken per session and could rate-limit itself halfway through.",
        "operationId": "revoke_other_sessions",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RevokeOthersResponse"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/sessions/{session_id}": {
      "delete": {
        "tags": [
          "account"
        ],
        "summary": "DELETE /api/account/sessions/{session_id} — session_id is the sid hash as\nreturned by the list endpoint (opaque to the client).",
        "operationId": "revoke_session",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "description": "Opaque session id from the list endpoint",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "404": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/healthz": {
      "get": {
        "tags": [
          "meta"
        ],
        "operationId": "healthz",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/recovery/redeem": {
      "post": {
        "tags": [
          "recovery"
        ],
        "summary": "POST /api/recovery/redeem — consume a one-time recovery code and issue an\nenroll-level session so a new passkey can be registered. There is no email\nstep: the code is the sole break-glass credential. On success every existing\nsession and refresh family is revoked (a reset, not an additive grant), so a\nstolen code can't silently coexist with the victim's live sessions. Reaching\na full session still requires a passkey login afterwards.",
        "operationId": "redeem",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RedeemRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Enroll-level session cookie set",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RedeemResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or expired code",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/session": {
      "get": {
        "tags": [
          "session"
        ],
        "summary": "GET /api/session — whoami for the SPA.",
        "operationId": "get",
        "responses": {
          "200": {
            "description": "Current user and session metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionInfo"
                }
              }
            }
          },
          "401": {
            "description": "No session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Enroll-level session (passkey login required)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/session/logout": {
      "post": {
        "tags": [
          "session"
        ],
        "summary": "POST /api/session/logout — destroys the IdP session and cascades:\nrevokes refresh families bound to it and dispatches back-channel logout\nto affected RPs.",
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "Session destroyed, cookie cleared",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "401": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/signup/finish": {
      "post": {
        "tags": [
          "signup"
        ],
        "summary": "POST /api/signup/finish — verify the passkey and activate the account\natomically with its first credential. Deliberately does NOT mint a full\nsession: the client then logs in with the new passkey (`login/finish`) to\nobtain one, so a full session always reflects a real, user-verified\nassertion (and `amr` is honest).",
        "operationId": "finish",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FinishRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "{ user_id, credential_id }"
          },
          "400": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/signup/pow": {
      "get": {
        "tags": [
          "signup"
        ],
        "summary": "GET /api/signup/pow — issue a one-time proof-of-work challenge the client\nmust solve before `signup/start`. A soft cost on mass automated signup\n(open registration has no email to lean on); not a Sybil/humanness proof.",
        "operationId": "pow",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PowChallenge"
                }
              }
            }
          },
          "429": {
            "description": "Rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/signup/start": {
      "post": {
        "tags": [
          "signup"
        ],
        "summary": "POST /api/signup/start — verify the proof-of-work, create a *pending*\naccount, and begin a passkey registration ceremony. No email, no username:\na nickname plus a passkey is the entire signup. Returns an enroll-level\nsession whose only capability is finishing this registration.",
        "operationId": "start",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "{ ceremony_id, user_id, options }; enroll session cookie set"
          },
          "400": {
            "description": "Bad nickname or proof of work",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/webauthn/login/finish": {
      "post": {
        "tags": [
          "webauthn"
        ],
        "summary": "POST /api/webauthn/login/finish — verify the assertion and issue a full\nsession. The asserted credential must belong to an existing, active account,\nand the assertion must be user-verified; only then is `amr=[\"webauthn\"]`\nminted. This is the sole path to a full session.",
        "operationId": "login_finish",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginFinishRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "{ user_id }"
          },
          "401": {
            "description": "Authentication failed"
          }
        }
      }
    },
    "/api/webauthn/login/start": {
      "post": {
        "tags": [
          "webauthn"
        ],
        "summary": "POST /api/webauthn/login/start — begin a usernameless, discoverable login\n(conditional UI / resident keys). Takes no identifier; the authenticator\nreveals which account on `finish`.",
        "operationId": "login_start",
        "responses": {
          "200": {
            "description": "{ ceremony_id, options }"
          }
        }
      }
    },
    "/api/webauthn/reauth/finish": {
      "post": {
        "tags": [
          "webauthn"
        ],
        "summary": "POST /api/webauthn/reauth/finish — verify the step-up assertion and stamp\n`reauth_at` on the current session. No new session is minted.",
        "operationId": "reauth_finish",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReauthFinishRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "{ ok: true }"
          },
          "401": {
            "description": ""
          },
          "403": {
            "description": ""
          }
        }
      }
    },
    "/api/webauthn/reauth/start": {
      "post": {
        "tags": [
          "webauthn"
        ],
        "summary": "POST /api/webauthn/reauth/start — begin a step-up assertion on the current\nfull session (we know the user, so allowCredentials is scoped to their\npasskeys). Used to gate sensitive operations like generating recovery codes.",
        "operationId": "reauth_start",
        "responses": {
          "200": {
            "description": "{ ceremony_id, options }"
          },
          "400": {
            "description": ""
          },
          "403": {
            "description": ""
          }
        }
      }
    },
    "/api/webauthn/register/finish": {
      "post": {
        "tags": [
          "webauthn"
        ],
        "summary": "POST /api/webauthn/register/finish — store the passkey. Never elevates the\nsession: `Full` is reachable only via `login/finish`, so registering a\npasskey (including during recovery) never by itself grants a full session.",
        "operationId": "register_finish",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterFinishRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "{ credential_id }"
          },
          "400": {
            "description": ""
          },
          "403": {
            "description": ""
          },
          "409": {
            "description": "Step-up re-authentication required"
          }
        }
      }
    },
    "/api/webauthn/register/start": {
      "post": {
        "tags": [
          "webauthn"
        ],
        "summary": "POST /api/webauthn/register/start — add a passkey to the current account\n(enroll or full session). Used to add backup passkeys, and to register a new\npasskey during recovery. Signup uses its own ceremony (`/api/signup/*`).",
        "operationId": "register_start",
        "responses": {
          "200": {
            "description": "{ ceremony_id, options }"
          },
          "401": {
            "description": ""
          },
          "409": {
            "description": "Step-up re-authentication required"
          }
        }
      }
    },
    "/oauth/token": {
      "post": {
        "tags": [
          "oidc"
        ],
        "summary": "POST /oauth/token — authorization_code (with PKCE) and refresh_token\ngrants for public clients.",
        "operationId": "token",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "OAuth error (RFC 6749 §5.2)"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DeletePasskeyResponse": {
        "type": "object",
        "required": [
          "ok",
          "current_session_revoked"
        ],
        "properties": {
          "current_session_revoked": {
            "type": "boolean",
            "description": "Whether the caller's own session was bound to the deleted passkey and\nhas therefore been revoked (the SPA should route back to sign-in)."
          },
          "ok": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Error envelope returned by every `/api/*` failure.",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string",
            "description": "Machine-readable error code, e.g. `rate_limited`, `account_exists`."
          },
          "message": {
            "type": "string"
          }
        }
      },
      "FinishRequest": {
        "type": "object",
        "required": [
          "ceremony_id",
          "credential"
        ],
        "properties": {
          "ceremony_id": {
            "type": "string"
          },
          "credential": {
            "type": "object",
            "description": "Raw `navigator.credentials.create()` result (standard WebAuthn shape)."
          },
