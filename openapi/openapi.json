{
  "openapi": "3.1.0",
  "info": {
    "title": "auth.ericminassian.com",
    "description": "Personal OIDC provider — SPA API and token endpoint.",
    "license": {
      "name": "MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/account": {
      "delete": {
        "tags": [
          "account"
        ],
        "summary": "DELETE /api/account — permanently delete the account and everything bound\nto it: passkeys, sessions (each cascading to refresh families +\nback-channel logout), then the user record itself.",
        "operationId": "delete_account",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "401": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/passkeys": {
      "get": {
        "tags": [
          "account"
        ],
        "summary": "GET /api/account/passkeys",
        "operationId": "list_passkeys",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PasskeyList"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/passkeys/{credential_id}": {
      "delete": {
        "tags": [
          "account"
        ],
        "summary": "DELETE /api/account/passkeys/{credential_id} — refuses to delete the last\npasskey (account lockout guard; recovery would be the only way back in).",
        "operationId": "delete_passkey",
        "parameters": [
          {
            "name": "credential_id",
            "in": "path",
            "description": "base64url credential id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "404": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Cannot delete the only passkey",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "account"
        ],
        "summary": "PATCH /api/account/passkeys/{credential_id}",
        "operationId": "rename_passkey",
        "parameters": [
          {
            "name": "credential_id",
            "in": "path",
            "description": "base64url credential id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RenameRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "404": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/sessions": {
      "get": {
        "tags": [
          "account"
        ],
        "summary": "GET /api/account/sessions",
        "operationId": "list_sessions",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionList"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/sessions/{session_id}": {
      "delete": {
        "tags": [
          "account"
        ],
        "summary": "DELETE /api/account/sessions/{session_id} — session_id is the sid hash as\nreturned by the list endpoint (opaque to the client).",
        "operationId": "revoke_session",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "description": "Opaque session id from the list endpoint",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "404": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/healthz": {
      "get": {
        "tags": [
          "meta"
        ],
        "operationId": "healthz",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/recovery/start": {
      "post": {
        "tags": [
          "recovery"
        ],
        "summary": "POST /api/recovery/start — sends a recovery OTP if the account exists.\nUniform 200 either way (anti-enumeration).",
        "operationId": "start",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/recovery/verify": {
      "post": {
        "tags": [
          "recovery"
        ],
        "summary": "POST /api/recovery/verify — consumes the OTP and issues an enroll-level\nsession on the existing account so a new passkey can be registered.",
        "operationId": "verify",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Enroll-level session cookie set",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or expired code",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/session": {
      "get": {
        "tags": [
          "session"
        ],
        "summary": "GET /api/session — whoami for the SPA.",
        "operationId": "get",
        "responses": {
          "200": {
            "description": "Current user and session metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionInfo"
                }
              }
            }
          },
          "401": {
            "description": "No session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Enroll-level session (passkey login required)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/session/logout": {
      "post": {
        "tags": [
          "session"
        ],
        "summary": "POST /api/session/logout — destroys the IdP session and cascades:\nrevokes refresh families bound to it and dispatches back-channel logout\nto affected RPs.",
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "Session destroyed, cookie cleared",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "401": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/signup/start": {
      "post": {
        "tags": [
          "signup"
        ],
        "summary": "POST /api/signup/start — sends an OTP (or an \"account exists\" notice).\nUniform 200 regardless of account existence (anti-enumeration).",
        "operationId": "start",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OTP dispatched (uniform regardless of account existence)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/signup/verify": {
      "post": {
        "tags": [
          "signup"
        ],
        "summary": "POST /api/signup/verify — consumes the OTP, creates the account, and\nissues an enroll-level session whose only capability is registering the\nfirst passkey.",
        "operationId": "verify",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Account created; enroll-level session cookie set",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or expired code",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Account already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/webauthn/login/finish": {
      "post": {
        "tags": [
          "webauthn"
        ],
        "summary": "POST /api/webauthn/login/finish — verifies the assertion and issues a\nfull session.",
        "description": "Body: `{ ceremony_id, credential }` where `credential` is the\n`navigator.credentials.get()` result. Returns `{ user_id }`.",
        "operationId": "login_finish",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginFinishRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "{ user_id }"
          },
          "401": {
            "description": "Authentication failed"
          }
        }
      }
    },
    "/api/webauthn/login/start": {
      "post": {
        "tags": [
          "webauthn"
        ],
        "summary": "POST /api/webauthn/login/start — no prior auth. Without an email this is\nthe discoverable (conditional-UI) flow; with one, an allowCredentials\nchallenge for that account. Unknown emails get a discoverable challenge\nso the response shape stays uniform.",
        "description": "Body: `{ email? }`. Returns `{ ceremony_id, options }` for\n`navigator.credentials.get()`.",
        "operationId": "login_start",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginStartRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "{ ceremony_id, options }"
          }
        }
      }
    },
    "/api/webauthn/register/finish": {
      "post": {
        "tags": [
          "webauthn"
        ],
        "summary": "POST /api/webauthn/register/finish — stores the passkey; upgrades an\nenroll session to full when it was the first registration step.",
        "description": "Body: `{ ceremony_id, credential, name? }` where `credential` is the\n`navigator.credentials.create()` result.",
        "operationId": "register_finish",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterFinishRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "{ credential_id }"
          },
          "400": {
            "description": ""
          },
          "403": {
            "description": ""
          }
        }
      }
    },
    "/api/webauthn/register/start": {
      "post": {
        "tags": [
          "webauthn"
        ],
        "summary": "POST /api/webauthn/register/start — enroll or full session.",
        "description": "Returns `{ ceremony_id, options }` where `options` is the raw\n`PublicKeyCredentialCreationOptions` to pass to `navigator.credentials\n.create()`. The shape is the standard WebAuthn structure (not modeled in\nthis schema).",
        "operationId": "register_start",
        "responses": {
          "200": {
            "description": "{ ceremony_id, options }"
          },
          "401": {
            "description": ""
          }
        }
      }
    },
    "/oauth/token": {
      "post": {
        "tags": [
          "oidc"
        ],
        "summary": "POST /oauth/token — authorization_code (with PKCE) and refresh_token\ngrants for public clients.",
        "operationId": "token",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "OAuth error (RFC 6749 §5.2)"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "description": "Error envelope returned by every `/api/*` failure.",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string",
            "description": "Machine-readable error code, e.g. `rate_limited`, `account_exists`."
          },
          "message": {
            "type": "string"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "version"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "LoginFinishRequest": {
        "type": "object",
        "required": [
          "ceremony_id",
          "credential"
        ],
        "properties": {
          "ceremony_id": {
            "type": "string"
          },
          "credential": {
            "type": "object",
            "description": "Raw `navigator.credentials.get()` result (standard WebAuthn shape)."
          }
        }
      },
      "LoginStartRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "OkResponse": {
        "type": "object",
        "description": "Generic success envelope (`{ \"ok\": true }`).",
        "required": [
          "ok"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "PasskeyInfo": {
        "type": "object",
        "required": [
          "credential_id",
          "name",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "integer",
            "format": "int64"
          },
          "credential_id": {
            "type": "string"
          },
          "last_used_at": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "PasskeyList": {
        "type": "object",
        "required": [
          "passkeys"
        ],
        "properties": {
          "passkeys": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PasskeyInfo"
            }
          }
        }
      },
      "RegisterFinishRequest": {
        "type": "object",
        "required": [
          "ceremony_id",
          "credential"
        ],
        "properties": {
          "ceremony_id": {
            "type": "string"
          },
          "credential": {
            "type": "object",
            "description": "Raw `navigator.credentials.create()` result (standard WebAuthn shape)."
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "RenameRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "SessionInfo": {
        "type": "object",
        "required": [
          "user",
          "session"
        ],
        "properties": {
          "session": {
            "$ref": "#/components/schemas/SessionMeta"
          },
          "user": {
            "$ref": "#/components/schemas/SessionUser"
          }
        }
      },
      "SessionList": {
        "type": "object",
        "required": [
          "sessions"
        ],
        "properties": {
          "sessions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SessionListItem"
            }
          }
        }
      },
      "SessionListItem": {
        "type": "object",
        "required": [
          "session_id",
          "created_at",
          "last_seen_at",
          "amr",
          "current"
        ],
        "properties": {
          "amr": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          },
          "current": {
            "type": "boolean"
          },
          "last_seen_at": {
            "type": "integer",
            "format": "int64"
          },
          "session_id": {
            "type": "string"
          }
        }
      },
      "SessionMeta": {
        "type": "object",
        "required": [
          "created_at",
          "amr"
        ],
        "properties": {
          "amr": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "SessionUser": {
        "type": "object",
        "required": [
          "user_id",
          "email"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "user_id": {
            "type": "string"
          }
        }
      },
      "StartRequest": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "TokenRequest": {
        "type": "object",
        "required": [
          "grant_type"
        ],
        "properties": {
          "client_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "code": {
            "type": [
              "string",
              "null"
            ]
          },
          "code_verifier": {
            "type": [
              "string",
              "null"
            ]
          },
          "grant_type": {
            "type": "string"
          },
          "redirect_uri": {
            "type": [
              "string",
              "null"
            ]
          },
          "refresh_token": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "required": [
          "access_token",
          "token_type",
          "expires_in",
          "scope"
        ],
        "properties": {
          "access_token": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer",
            "format": "int64"
          },
          "id_token": {
            "type": [
              "string",
              "null"
            ]
          },
          "refresh_token": {
            "type": [
              "string",
              "null"
            ]
          },
          "scope": {
            "type": "string"
          },
          "token_type": {
            "type": "string"
          }
        }
      },
      "VerifyRequest": {
        "type": "object",
        "required": [
          "email",
          "code"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        }
      },
      "VerifyResponse": {
        "type": "object",
        "required": [
          "user_id"
        ],
        "properties": {
          "user_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "meta",
      "description": "Health and metadata"
    },
    {
      "name": "signup",
      "description": "Account creation (email OTP)"
    },
    {
      "name": "recovery",
      "description": "Account recovery (email OTP)"
    },
    {
      "name": "webauthn",
      "description": "Passkey registration and login"
    },
    {
      "name": "session",
      "description": "Session lifecycle"
    },
    {
      "name": "account",
      "description": "Passkey and session management"
    },
    {
      "name": "oidc",
      "description": "OAuth 2.1 / OIDC endpoints"
    }
  ]
}
